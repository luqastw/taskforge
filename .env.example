# Application
APP_NAME=TaskForge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=taskforge
DB_USERNAME=taskforge
DB_PASSWORD=taskforge

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Cache
CACHE_STORE=redis
CACHE_PREFIX=taskforge_cache

# Queue
QUEUE_CONNECTION=redis
QUEUE_PREFIX=taskforge_queue

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Broadcasting
BROADCAST_CONNECTION=log

# Mail
MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@taskforge.local"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (para S3 futuramente)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1
SANCTUM_GUARD=web

# Telescope (desabilitado por padrão)
TELESCOPE_ENABLED=false

# Horizon (para produção)
HORIZON_ENABLED=false

# Webhook
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_BACKOFF=60,300,900

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=5

